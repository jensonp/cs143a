digraph G {
  graph [rankdir=LR, pad=0.25, nodesep=0.45, ranksep=0.6, splines=true, bgcolor="white"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", color="#5B6B73", fontcolor="#233238"];
  edge [color="#5B6B73", penwidth=1.05, arrowsize=0.75, fontname="Helvetica", fontsize=10];

  labelloc="t";
  label="Control loop: timer/traps re-enter the kernel; scheduler returns to user code";

  cpu [fillcolor="#F5F5F5", label="CPU executes\nuser code"];
  timer [fillcolor="#DDEAF1", label="timer interrupt\n(preemption)"];
  trap [fillcolor="#DDEAF1", label="syscall / fault\n(trap)"];

  subgraph cluster_kernel {
    label="kernel control path";
    color="#9EC9DA";
    style="rounded,filled";
    fillcolor="#EAF6FB";

    sched [fillcolor="#BFE2F1", label="scheduler\ndecides next"];
    rq [fillcolor="#D5EDF7", label="runnable set\n(queues/metadata)"];
    dispatch [fillcolor="#BFE2F1", label="dispatcher\n(save/restore state)"];

    sched -> rq -> dispatch;
  }

  cpu -> trap [label="request/violation"];
  cpu -> timer [label="time slice"];
  trap -> sched [label="enter kernel"];
  timer -> sched [label="enter kernel"];
  dispatch -> cpu [label="return to user"];
}
