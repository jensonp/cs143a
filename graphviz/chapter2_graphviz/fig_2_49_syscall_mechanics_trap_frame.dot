digraph G {
  graph [rankdir=TB, pad=0.2, bgcolor="white"];
  node [shape=plain, fontname="Helvetica"];

  trace [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="7" COLOR="#5B6B73">
      <TR>
        <TD BGCOLOR="#F5F5F5"><B>Stage</B></TD>
        <TD BGCOLOR="#F5F5F5"><B>User + wrapper</B></TD>
        <TD BGCOLOR="#F5F5F5"><B>CPU / hardware</B></TD>
        <TD BGCOLOR="#F5F5F5"><B>Kernel</B></TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>1) Package intent</B></TD>
        <TD>place syscall number + args per ABI (often registers; sometimes pointer to arg block)</TD>
        <TD>still in user mode</TD>
        <TD>not executing yet</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>2) Enter kernel</B></TD>
        <TD>executes special entry instruction (`syscall`/`sysenter`/trap)</TD>
        <TD>switches privilege to kernel mode; jumps to entry point</TD>
        <TD>entry path begins</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>3) Save state</B></TD>
        <TD>caller is paused at boundary</TD>
        <TD>saves resumable snapshot (PC/flags/regs) as a trap frame</TD>
        <TD>has a durable record to resume/return later</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>4) Dispatch</B></TD>
        <TD>-</TD>
        <TD>-</TD>
        <TD>uses syscall number to select a handler; validates arguments</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>5) Execute</B></TD>
        <TD>-</TD>
        <TD>-</TD>
        <TD>updates authoritative state; may block, sleep, or schedule others</TD>
      </TR>
      <TR>
        <TD BGCOLOR="#E6F3F9"><B>6) Return</B></TD>
        <TD>receives return value or error via ABI</TD>
        <TD>restores saved state; executes controlled return to user mode</TD>
        <TD>completes syscall and resumes the user instruction stream</TD>
      </TR>
    </TABLE>
  >];
}

